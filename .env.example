# Gemini API Key (required)
# Get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Rate limit per IP per hour (optional, default: 30)
# RATE_LIMIT_MAX=30

# Resend API key — required for the feedback endpoint to send emails.
# Sign up at https://resend.com and create an API key.
RESEND_API_KEY=

# Email address that receives feedback reports.
# Defaults to myName@gmail.com if not set.
# FEEDBACK_RECIPIENT_EMAIL=
